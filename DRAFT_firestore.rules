rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    function getEmail() {
      return string(request.auth.token.get('email', request.auth.token.get('email_address', ''))).lower();
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasUserRole(role) {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == role;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        getEmail() == "ygbock@gmail.com" ||
        hasUserRole("superadmin")
      );
    }

    function isDistrictLeader(districtId) {
      return isSignedIn() && (
        isSuperAdmin() ||
        (hasUserRole("district") && (districtId == 'any' || getUserData().districtId == districtId)) ||
        (getEmail() != "" && 
         exists(/databases/$(database)/documents/accessControl/$(getEmail())) && 
         get(/databases/$(database)/documents/accessControl/$(getEmail())).data.role == "district" && 
         (districtId == 'any' || get(/databases/$(database)/documents/accessControl/$(getEmail())).data.districtId == districtId))
      );
    }

    function isBranchAdmin(districtId, branchId) {
      return isSignedIn() && (
        isDistrictLeader(districtId) ||
        (hasUserRole("admin") && (branchId == 'any' || getUserData().branchId == branchId)) ||
        (getEmail() != "" && 
         exists(/databases/$(database)/documents/accessControl/$(getEmail())) && 
         get(/databases/$(database)/documents/accessControl/$(getEmail())).data.role == "admin" && 
         (branchId == 'any' || get(/databases/$(database)/documents/accessControl/$(getEmail())).data.branchId == branchId))
      );
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'fullName', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.fullName is string && data.fullName.size() <= 100 &&
             data.email == getEmail();
    }

    function isValidMember(data) {
      return data.keys().hasAll(['fullName', 'branchId', 'level', 'status']) &&
             data.fullName is string && data.fullName.size() <= 100 &&
             data.branchId is string &&
             data.level in ['Convert', 'Disciple', 'Worker', 'Leader'] &&
             data.status in ['Active', 'Pending', 'Inactive'];
    }

    function isValidAttendance(data) {
      return data.keys().hasAll(['timestamp', 'recordedBy']) &&
             data.keys().size() == 2 &&
             data.timestamp == request.time &&
             data.recordedBy == request.auth.uid;
    }

    function isValidEvent(data) {
      return data.keys().hasAll(['title', 'date', 'branchId']) &&
             data.title is string && data.title.size() <= 200 &&
             data.branchId is string;
    }

    // --- Collections ---

    match /accessControl/{email} {
      allow get: if isSignedIn() && (getEmail() == email.lower() || isSuperAdmin() || isVerified());
      allow list: if isSuperAdmin() || (isSignedIn() && isVerified() && isDistrictLeader('any'));
      allow write: if isSuperAdmin() || getEmail() == email.lower();
    }

    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isSuperAdmin() || isDistrictLeader('any'));
      allow create, update: if isSignedIn() && request.auth.uid == uid && isValidUser(incoming());
      allow delete: if isSuperAdmin();
    }

    match /districts/{districtId} {
      allow read, list: if isSignedIn();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() || isDistrictLeader(districtId);
      
      match /branches/{branchId} {
        allow read, list: if isSignedIn();
        allow write: if isSuperAdmin() || isDistrictLeader(districtId);
        
        match /members/{memberId} {
          allow read: if isBranchAdmin(districtId, branchId) || (isSignedIn() && request.auth.uid == memberId);
          allow list: if isBranchAdmin(districtId, branchId);
          allow write: if isBranchAdmin(districtId, branchId) && isValidMember(incoming());
        }

        match /transactions/{transactionId} {
          allow read, write: if isBranchAdmin(districtId, branchId);
        }

        match /departments/{deptId} {
          allow read: if isSignedIn();
          allow write: if isBranchAdmin(districtId, branchId);
        }

        match /events/{eventId} {
          allow read, list: if isSignedIn();
          allow write: if isBranchAdmin(districtId, branchId) && isValidEvent(incoming());

          match /attendance/{attendeeId} {
            // Fix for the reported error: explicitly allow list/read
            // Using isVerified() for write as per instructions
            allow read, list: if isBranchAdmin(districtId, branchId);
            allow create: if isBranchAdmin(districtId, branchId) && isVerified() && isValidAttendance(incoming());
            allow delete: if isBranchAdmin(districtId, branchId) && isVerified();
          }
        }

        match /tasks/{taskId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn();
          allow update: if isSignedIn() && (
            isBranchAdmin(districtId, branchId) || 
            existing().assigneeId == request.auth.uid || 
            existing().createdBy == request.auth.uid
          );
          allow delete: if isSignedIn() && (
            isBranchAdmin(districtId, branchId) || 
            existing().createdBy == request.auth.uid
          );
        }
      }
    }

    match /invites/{inviteId} {
      allow read: if true;
      allow create: if isSignedIn() && (isSuperAdmin() || isDistrictLeader('any'));
      allow update: if isSignedIn();
    }

    match /adminRequests/{requestId} {
      allow create: if true;
      allow read, write: if isSuperAdmin() || isDistrictLeader('any');
    }

    // Collection Group Helpers
    match /{path=**}/members/{memberId} {
      allow read: if isBranchAdmin('any', 'any') || (isSignedIn() && request.auth.uid == memberId);
      allow list: if isSuperAdmin() || isDistrictLeader('any') || isBranchAdmin('any', 'any');
    }
    
    match /{path=**}/branches/{branchId} {
      allow read, list: if isSignedIn();
    }
    
    match /{path=**}/events/{eventId} {
      allow read, list: if isSignedIn();
    }
  }
}
