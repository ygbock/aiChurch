rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    
    function getEmail() {
      // Robust email extraction
      return string(request.auth.token.get('email', request.auth.token.get('email_address', ''))).lower();
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        getEmail() == "ygbock@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "superadmin")
      );
    }

    function isDistrictLeader(districtId) {
      return isSignedIn() && (
        isSuperAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "district" && 
         (districtId == 'any' || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.districtId == districtId)) ||
        (getEmail() != "" && 
         exists(/databases/$(database)/documents/accessControl/$(getEmail())) && 
         get(/databases/$(database)/documents/accessControl/$(getEmail())).data.role == "district" && 
         (districtId == 'any' || get(/databases/$(database)/documents/accessControl/$(getEmail())).data.districtId == districtId))
      );
    }

    function isBranchAdmin(districtId, branchId) {
      return isSignedIn() && (
        isDistrictLeader(districtId) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.branchId == branchId) ||
        (getEmail() != "" && 
         exists(/databases/$(database)/documents/accessControl/$(getEmail())) && 
         get(/databases/$(database)/documents/accessControl/$(getEmail())).data.role == "admin" && 
         get(/databases/$(database)/documents/accessControl/$(getEmail())).data.branchId == branchId)
      );
    }

    // --- Collections ---

    match /accessControl/{email} {
      allow get, list: if isSignedIn() && (
        getEmail() == email.lower() || 
        isSuperAdmin() ||
        (resource != null && isDistrictLeader(resource.data.get('districtId', 'any')))
      );
      // Users can write their own accessControl record (e.g. during registration)
      // Admins/Superadmins can manage accessControl
      allow write: if isSignedIn() && (
        isSuperAdmin() || 
        getEmail() == email.lower() ||
        (request.resource != null && isDistrictLeader(request.resource.data.get('districtId', 'any')))
      );
    }

    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isSuperAdmin() || isDistrictLeader('any'));
      // Simplified: Allow users to manage their own profile
      allow create, update: if isSignedIn() && request.auth.uid == uid;
      allow delete: if isSuperAdmin();
    }

    match /districts/{districtId} {
      allow read, list: if isSignedIn();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() || isDistrictLeader(districtId);
      
      match /branches/{branchId} {
        allow read, list: if isSignedIn();
        allow write: if isSuperAdmin() || isDistrictLeader(districtId);
        
        match /members/{memberId} {
          allow read: if isBranchAdmin(districtId, branchId) || (isSignedIn() && request.auth.uid == memberId);
          allow write: if isBranchAdmin(districtId, branchId);
        }

        match /transactions/{transactionId} {
          allow read, write: if isBranchAdmin(districtId, branchId);
        }

        match /departments/{deptId} {
          allow read: if isSignedIn();
          allow write: if isBranchAdmin(districtId, branchId);
        }

        match /events/{eventId} {
          allow read: if isSignedIn();
          allow write: if isBranchAdmin(districtId, branchId);
        }
      }
    }

    match /invites/{inviteId} {
      allow read: if true;
      allow create: if isSignedIn() && (isSuperAdmin() || isDistrictLeader('any'));
      allow update: if isSignedIn();
    }

    match /adminRequests/{requestId} {
      allow create: if true;
      allow read, write: if isSuperAdmin() || isDistrictLeader('any');
    }

    // Collection Group Helpers
    match /{path=**}/members/{memberId} {
      allow read: if isSignedIn() && (
        isSuperAdmin() || 
        isDistrictLeader(resource.data.get('districtId', 'any')) ||
        request.auth.uid == memberId ||
        getEmail() == resource.data.get('email', '').lower()
      );
    }
    
    match /{path=**}/events/{eventId} {
      allow read, list: if isSignedIn();
      allow write: if isSuperAdmin();
    }
    
    match /events/{eventId} {
      allow read, list: if isSignedIn();
      allow write: if isSuperAdmin() || isDistrictLeader('any');
    }
    
    match /{path=**}/branches/{branchId} {
      allow read: if isSignedIn();
    }
    
    // Support for branch creation (subcollection of districts)
    match /{path=**}/branches/{branchId} {
      allow write: if isSuperAdmin() || (request.resource != null && isDistrictLeader(request.resource.data.get('districtId', 'any')));
    }
  }
}
