{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user of the FaithFlow application (staff or admin).",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["superadmin", "admin", "district", "member"] },
        "districtId": { "type": "string", "description": "Required if role is district" },
        "branchId": { "type": "string", "description": "Required if role is admin or member" },
        "availability": {
          "type": "object",
          "properties": {
             "enabled": { "type": "boolean" },
             "days": { "type": "array", "items": { "type": "string" } },
             "startTime": { "type": "string" },
             "endTime": { "type": "string" }
          }
        },
        "notificationPrefs": {
          "type": "object",
          "properties": {
             "bookings": { "type": "boolean" },
             "reminders": { "type": "boolean" },
             "events": { "type": "boolean" },
             "news": { "type": "boolean" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "fullName", "email", "role"]
    },
    "Member": {
      "title": "Member",
      "description": "Information about a congregation member.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "dob": { "type": "string", "format": "date" },
        "gender": { "type": "string", "enum": ["Male", "Female"] },
        "maritalStatus": { "type": "string", "enum": ["Single", "Married", "Widowed", "Divorced"] },
        "address": { "type": "string" },
        "branchId": { "type": "string" },
        "level": { "type": "string", "enum": ["Convert", "Disciple", "Worker", "Leader"] },
        "status": { "type": "string", "enum": ["Active", "Pending", "Inactive"] },
        "photoUrl": { "type": "string" },
        "isBaptised": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "branchId", "level", "status"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial records (tithes, offerings, expenses).",
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "branchId": { "type": "string" },
        "recordedBy": { "type": "string", "description": "UID of the admin who recorded it" }
      },
      "required": ["amount", "type", "category", "date", "branchId"]
    },
    "Event": {
      "title": "Event",
      "description": "Church services, conferences, and meetings.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "time": { "type": "string" },
        "location": { "type": "string" },
        "branchId": { "type": "string" },
        "type": { "type": "string", "enum": ["Service", "Youth", "Conference", "Meetings", "Outreach"] },
        "recurrence": {
          "type": "object",
          "properties": {
            "isRecurring": { "type": "boolean" },
            "frequency": { "type": "string", "enum": ["daily", "weekly", "monthly"] },
            "days": { "type": "array", "items": { "type": "string" } },
            "until": { "type": "string", "format": "date" }
          }
        }
      },
      "required": ["title", "date", "branchId"]
    },
    "EventAttendance": {
      "title": "Event Attendance",
      "description": "Records representing a member's attendance at a specific event instance.",
      "type": "object",
      "properties": {
        "memberId": { "type": "string" },
        "memberName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["present", "late", "excused"] }
      },
      "required": ["memberId", "memberName", "timestamp"]
    },
    "Branch": {
      "title": "Branch",
      "description": "Church branch in a district.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "location": { "type": "string" },
        "capacity": { "type": "number" },
        "districtId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "districtId"]
    },
    "Department": {
      "title": "Department",
      "description": "Organizational unit or ministry within a branch.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "mission": { "type": "string" },
        "headId": { "type": "string" },
        "headName": { "type": "string" },
        "branchId": { "type": "string" },
        "isVisible": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category", "branchId"]
    },
    "TransferRequest": {
      "title": "Transfer Request",
      "description": "A request to move a member from one branch to another.",
      "type": "object",
      "properties": {
        "memberId": { "type": "string" },
        "memberName": { "type": "string" },
        "fromBranchId": { "type": "string" },
        "fromBranchName": { "type": "string" },
        "fromDistrictId": { "type": "string" },
        "toBranchId": { "type": "string" },
        "toBranchName": { "type": "string" },
        "toDistrictId": { "type": "string" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "requestedBy": { "type": "string" },
        "requestedAt": { "type": "string", "format": "date-time" },
        "resolvedBy": { "type": "string" },
        "resolvedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["memberId", "fromBranchId", "toBranchId", "status", "requestedBy"]
    },
    "Task": {
      "title": "Task",
      "description": "Operational tasks and assignments.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "dept": { "type": "string" },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High"] },
        "dueDate": { "type": "string", "format": "date" },
        "assigneeId": { "type": "string" },
        "assigneeName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in-progress", "completed"] },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "branchId": { "type": "string" }
      },
      "required": ["title", "priority", "status", "assigneeId", "branchId"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Record of a member's attendance at an event.",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "recordedBy": { "type": "string", "description": "UID of the person who scanned the member" }
      },
      "required": ["timestamp", "recordedBy"]
    },
    "QueueEntry": {
      "title": "Queue Entry",
      "description": "An entry in a queue for an event.",
      "type": "object",
      "properties": {
        "ticketNumber": { "type": "string" },
        "status": { "type": "string", "enum": ["waiting", "serving", "completed", "cancelled"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "servedAt": { "type": "string", "format": "date-time" },
        "counter": { "type": "string" }
      },
      "required": ["ticketNumber", "status", "timestamp"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Scheduled appointments with clients or members.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "clientName": { "type": "string" },
        "clientEmail": { "type": "string", "format": "email" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "duration": { "type": "string" },
        "location": { "type": "string" },
        "type": { "type": "string" },
        "sessionFormat": { "type": "string", "enum": ["physical", "virtual", "phone"] },
        "duration": { "type": "string", "enum": ["30 mins", "1 hour", "1.5 hours"] },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled", "completed"] },
        "notes": { "type": "string" },
        "staffId": { "type": "string", "description": "UID of the pastor/staff member being booked" },
        "staffName": { "type": "string" },
        "staffFeedback": { "type": "string", "description": "Notes from the pastor during approval/decline" },
        "requesterId": { "type": "string", "description": "UID of the member who booked the session" },
        "growthSteps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "completed": { "type": "boolean" },
              "dueDate": { "type": "string", "format": "date" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "clientName", "date", "time", "status"]
    },
    "StaffNote": {
      "title": "Staff Note",
      "description": "Private sensitive notes from a counselor or guide.",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["content", "authorId"]
    },
    "CalendarEvent": {
      "title": "Calendar Event",
      "description": "General events for the church calendar.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "location": { "type": "string" },
        "type": { "type": "string" },
        "recurrence": {
          "type": "object",
          "properties": {
            "isRecurring": { "type": "boolean" },
            "frequency": { "type": "string", "enum": ["daily", "weekly", "monthly"] },
            "days": { "type": "array", "items": { "type": "string" } },
            "until": { "type": "string", "format": "date" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "date"]
    },
    "Reminder": {
      "title": "Reminder",
      "description": "Personal reminders for users.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "date", "status", "userId"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A conversation between users.",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["participants"]
    },
    "Message": {
      "title": "Message",
      "description": "A message within a chat.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "text", "createdAt"]
    },
    "BaptismProgram": {
      "title": "Baptism Program",
      "description": "A program for baptism.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "targetDate": { "type": "string" },
        "baptismDate": { "type": "string" },
        "baptismOfficiator": { "type": "string" },
        "baptismLocation": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Completed", "Rescheduled"] },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "targetDate", "status"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "Private user profiles."
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Chat meta-data between users."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Individual messages in a chat."
    },
    "/users/{uid}/reminders/{reminderId}": {
      "schema": "Reminder",
      "description": "Personal reminders for the user."
    },
    "/transfers/{transferId}": {
      "schema": "TransferRequest",
      "description": "Member transfer requests."
    },
    "/districts/{districtId}/branches/{branchId}": {
      "schema": "Branch",
      "description": "Branch records scoped by district."
    },
    "/districts/{districtId}/branches/{branchId}/departments/{departmentId}": {
      "schema": "Department",
      "description": "Department records scoped by branch."
    },
    "/districts/{districtId}/branches/{branchId}/members/{memberId}": {
      "schema": "Member",
      "description": "Member records scoped by district and branch."
    },
    "/districts/{districtId}/branches/{branchId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Financial records scoped by branch."
    },
    "/districts/{districtId}/branches/{branchId}/events/{eventId}": {
      "schema": "Event",
      "description": "Events scoped by branch."
    },
    "/districts/{districtId}/branches/{branchId}/events/{eventId}/attendance/{attendeeId}": {
      "schema": "Attendance",
      "description": "Attendance records for an event."
    },
    "/districts/{districtId}/branches/{branchId}/events/{eventId}/queueEntries/{entryId}": {
      "schema": "QueueEntry",
      "description": "Queue entries for an event."
    },
    "/districts/{districtId}/branches/{branchId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "Tasks scoped by branch."
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Collection of appointments."
    },
    "/calendar_events/{eventId}": {
      "schema": "CalendarEvent",
      "description": "Collection of global calendar events."
    },
    "/baptismPrograms/{programId}": {
      "schema": "BaptismProgram",
      "description": "Collection of baptism programs."
    }
  }
}
